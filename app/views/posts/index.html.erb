<h1 class="text-2xl font-bold mb-4">投稿一覧</h1>

<%= link_to "新規投稿", new_post_path, class: "inline-block px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600" %>

<div class="mt-6 space-y-4">
  <% @posts.each do |post| %>
    <div class="border p-4 rounded shadow flex justify-between items-center">
      <div>
        <h2 class="text-xl font-semibold">
          <%= link_to post.title, post_path(post), class: "text-blue-700 hover:underline" %>
        </h2>
        <p class="text-gray-600"><%= truncate(post.body, length: 100) %></p>
      </div>

      <div class="space-x-2">
        <%= link_to "編集", edit_post_path(post), class: "px-3 py-1 bg-yellow-500 text-white rounded hover:bg-yellow-600" %>
        <%= link_to "削除", post_path(post), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "px-3 py-1 bg-red-600 text-white rounded hover:bg-red-700" %>
      </div>
    </div>
  <% end %>
</div>
